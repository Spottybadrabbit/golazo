# Copy to .env.local and fill in. .env* is gitignored.

# ---- Clerk: fan auth (Sign in with Solana) ----
# Populated after `clerk auth login` + `clerk init --app app_3GgKtJr1k57Efty7X2tUEhpXZX2`.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# ---- Feed mode ----
# "sim"  = deterministic simulator (default, no creds needed)
# "live" = TxODDS TxLINE devnet feed (needs the service wallet below)
TXLINE_MODE=sim
# Client-side mirror of TXLINE_MODE. The browser bundle can only read
# NEXT_PUBLIC_-prefixed vars, so this must be set to the SAME value as
# TXLINE_MODE above for the browser to actually switch feeds (useLiveWorld
# polls GET /api/live instead of running the local simulator heartbeat).
NEXT_PUBLIC_FEED_MODE=sim

# ---- TxLINE devnet (TxODDS) — public network identifiers ----
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
SOLANA_RPC_URL=https://api.devnet.solana.com
TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
TXLINE_TXL_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG

# Golazo SERVICE wallet secret (base58 string or path to a keypair json).
# This is Golazo's own wallet, NOT a fan's. Needs devnet SOL. NEVER commit.
# Generate with:  npm run txline:wallet
TXLINE_SERVICE_WALLET=
